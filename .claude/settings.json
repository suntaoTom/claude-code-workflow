{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-hardcode.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "ConversationStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-tasks-status.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-check.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
