{
  "private": true,
  "name": "ai-frontend-automation",
  "description": "AI 前端自动化框架 — 根目录负责 agent 命令/规则/文档, workspace/ 负责实际项目代码",
  "scripts": {
    "dev": "pnpm --prefix workspace dev",
    "build": "pnpm --prefix workspace build",
    "lint": "pnpm --prefix workspace lint",
    "test": "pnpm --prefix workspace test",
    "gen:api": "pnpm --prefix workspace gen:api",
    "prd:import": "pnpm --prefix workspace prd:import",
    "install:workspace": "cd workspace && pnpm install"
  }
}
